{
    "version": 2,
    "builds": [
        {
            "src": "student_job_portal/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "student_job_portal/wsgi.py"
        }
    ],
    "regions": [
        "sin1"
    ]
}